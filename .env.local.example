# 管理密码(可选,推荐设置)
# 设置后,/admin 的上传与删除操作都需要在请求头里带上此密码。
ADMIN_PASSWORD=change-this-password

# ─── Cloudflare R2 视频存储配置 ───
# 在 Cloudflare 控制台 → R2 → 对应 Bucket → Settings 里可找到下列值。
# Account ID:                    R2 概览页右上角的账户 ID
# Access Key ID / Secret:        创建 R2 API Token(权限:对象读和写)后获得
# Bucket:                        存储桶名称
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# R2 公开访问基础域名,用于拼接视频播放 URL。
# 推荐:绑定自定义域名(如 https://cdn.example.com)→ Settings → Public access。
# 临时:也可启用 r2.dev 公开地址(如 https://pub-xxxx.r2.dev),仅用于测试,有速率限制。
R2_PUBLIC_BASE_URL=
